              <div style="display:flex;gap:6px">
                <button class="export-btn" style="padding:3px 10px;font-size:.68rem" onclick="renderAdminChatList();showToast('🔄 Daftar chat diperbarui')" title="Muat ulang daftar percakapan">🔄</button>
                <button class="export-btn" style="padding:3px 10px;font-size:.68rem" onclick="hapusSemuaChat()" title="Hapus semua percakapan">🧹</button>
              </div>
            </div>
            <div class="chat-list" id="adminChatList">
              <div style="padding:32px 16px;text-align:center;color:var(--muted);font-size:.84rem">Belum ada percakapan masuk.</div>
            </div>
          </div>

          <!-- Area chat utama -->
          <div class="chat-main" style="display:flex;flex-direction:column;flex:1;min-height:0;">
            <!-- Empty state -->
            <div class="chat-empty" id="chatEmptyState" style="display:flex">
              <div class="chat-empty-icon">💬</div>
              <p>Pilih percakapan untuk mulai membalas</p>
            </div>
            <!-- Active chat area -->
            <div id="chatActiveArea" style="display:none;flex-direction:column;flex:1;min-height:0;">
              <div class="chat-topbar" id="chatTopbar"></div>
              <div class="chat-messages" id="adminMessages" style="flex:1;overflow-y:auto;"></div>
              <div class="chat-inputbar">
                <textarea class="chat-input" id="adminInput" placeholder="Ketik balasan sebagai Admin..." rows="1"
                  onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();adminSend()}"
                  oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
                <button class="chat-send-btn" onclick="adminSend()" title="Kirim Balasan">➤</button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script>
// ===================== KONFIGURASI PENYIMPANAN BERSAMA =====================
// PENTING: Kunci localStorage di bawah HARUS SAMA dengan yang dipakai di klien.html
// agar data konsultasi & chat klien tersinkron ke Admin Panel ini.
// Buka klien.html dan admin.html dari domain/origin yang sama (mis. lewat
// web server lokal), bukan dengan double-click file terpisah, supaya
// localStorage benar-benar dibagi antar keduanya.
//
// ===================== ⚠️ BATASAN PENTING: MULTI-KLIEN BERSAMAAN =====================
// Sistem ini mendukung BANYAK percakapan klien sekaligus — semua chat yang masuk
// akan tampil sebagai daftar terpisah di sidebar tab "Chat Konsultasi" (lengkap
// dengan badge jumlah belum dibaca, diurutkan otomatis), dan admin bisa klik
// satu per satu untuk membalas.
//
// Karena datanya disimpan di localStorage BROWSER (tanpa server), ada 1 catatan:
// localStorage TIDAK dibagi antar device/HP yang berbeda. Jika klien membuka
// klien.html dari HP-nya sendiri dan Admin membuka admin.html dari laptop yang
// berbeda, chat klien tersebut TIDAK akan muncul di Admin (karena beda penyimpanan).
// Untuk produksi sungguhan (chat lintas device real-time), sistem ini perlu
// backend + database (server bersama).
//
// ✅ TESTING/DEMO multi-klien di SATU komputer (tanpa incognito):
// - Buka admin.html di satu tab.
// - Buka klien.html di tab lain -> ini "Klien #1".
// - Buka tab BARU lagi (Ctrl/Cmd+T), buka klien.html lagi -> otomatis jadi
//   "Klien #2" yang berbeda (ID klien disimpan per-tab via sessionStorage).
// - Ulangi untuk Klien #3, #4, dst — setiap tab baru = klien baru.
// - Setiap kali klien kirim chat, percakapan baru akan muncul di sidebar
//   "Chat Konsultasi" admin (klik 🔄 untuk refresh instan jika perlu).
const LS_DATA = 'alf_konsultasi_data';
const LS_CHAT = 'alf_chat_store';
const LS_PAY = 'alf_pembayaran_data';

// ===================== AUTENTIKASI ADMIN (sederhana, front-end only) =====================
// ⚠️ GANTI username & password di bawah ini sebelum digunakan!
// Catatan keamanan: karena ini berjalan 100% di browser (tanpa server),
// siapapun yang membuka "View Source" / DevTools bisa melihat nilai ini.
// Login ini hanya mencegah pengunjung biasa membuka dashboard secara tidak
// sengaja. Untuk keamanan data klien yang sesungguhnya (anti-bocor dari
// "oknum"), gunakan backend + autentikasi server + database.
const ADMIN_USER = 'admin';
const ADMIN_PASS = 'AlifahAdmin#2026';

const SESSION_KEY = 'alf_admin_session';

function doLogin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  const err = document.getElementById('loginError');

  if (u === ADMIN_USER && p === ADMIN_PASS) {
    sessionStorage.setItem(SESSION_KEY, '1');
    err.classList.remove('show');
    enterAdmin();
  } else {
    err.classList.add('show');
  }
}

function doLogout() {
  sessionStorage.removeItem(SESSION_KEY);
  document.getElementById('adminApp').style.display = 'none';
  document.getElementById('loginPage').style.display = 'flex';
  document.getElementById('loginUser').value = '';
  document.getElementById('loginPass').value = '';
}

function enterAdmin() {
  document.getElementById('loginPage').style.display = 'none';
  document.getElementById('adminApp').style.display = 'block';
  initAdminData();
  updateDashboard();
}

// ===================== DATA STORE =====================
let data = [];
let payData = [];
let sortKey = 'id', sortAsc = false;
let paySortKey = 'id', paySortAsc = false;

function loadData() {
  try { return JSON.parse(localStorage.getItem(LS_DATA) || '[]'); }
  catch(e) { return []; }
}
function save() {
  localStorage.setItem(LS_DATA, JSON.stringify(data));
}
function loadPayData() {
  try { return JSON.parse(localStorage.getItem(LS_PAY) || '[]'); }
  catch(e) { return []; }
}
function savePayData() {
  localStorage.setItem(LS_PAY, JSON.stringify(payData));
}

// Isi data contoh HANYA jika belum ada data sama sekali (mode demo)
function seedSampleData() {
  const sampleNames = ['Budi Santoso','Siti Rahayu','Ahmad Fauzi','Dewi Lestari','Raka Wijaya','Nia Sari','Hendra Gunawan','Anisa Putri'];
  const bidangList = ['Hukum Perdata','Hukum Pidana','Hukum Bisnis','Hukum Keluarga','Hukum Administrasi','HAKI'];
  const statusList = ['Menunggu','Diproses','Selesai','Selesai','Selesai'];
  const urgList = ['Normal (1–3 hari)','Segera (24 jam)','Darurat (hari ini)'];

  for (let i = 0; i < 16; i++) {
    const d = new Date(); d.setDate(d.getDate() - Math.floor(Math.random()*90));
    data.push({
      id: i + 1,
      nama: sampleNames[i % sampleNames.length],
      nik: '327' + Math.floor(Math.random() * 1e10).toString().padStart(10,'0'),
      email: sampleNames[i % sampleNames.length].split(' ')[0].toLowerCase() + '@email.com',
      telp: '0812' + Math.floor(Math.random() * 1e7).toString().padStart(7,'0'),
      bidang: bidangList[Math.floor(Math.random() * bidangList.length)],
      urgensi: urgList[Math.floor(Math.random() * urgList.length)],
      alamat: 'Jakarta Selatan',
      deskripsi: 'Permasalahan hukum terkait ' + bidangList[Math.floor(Math.random()*bidangList.length)].toLowerCase(),
      status: statusList[Math.floor(Math.random() * statusList.length)],
      tanggal: d.toISOString().split('T')[0]
    });
  }
  save();
}

function initAdminData() {
  data = loadData();
  if (data.length === 0) {
    seedSampleData(); // hapus baris ini jika tidak ingin data contoh
  }
  payData = loadPayData();
  updatePayBadge();
}

// ===================== NAVIGASI TAB =====================
function switchTab(tab, el) {
  document.querySelectorAll('.dash-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-overview').style.display = tab === 'overview' ? 'block' : 'none';
  document.getElementById('tab-data').style.display = tab === 'data' ? 'block' : 'none';
  document.getElementById('tab-pembayaran').style.display = tab === 'pembayaran' ? 'block' : 'none';
  document.getElementById('tab-chat').style.display = tab === 'chat' ? 'block' : 'none';
  if (tab === 'data') renderTable();
  if (tab === 'pembayaran') { renderPaymentTable(); updatePayBadge(true); }
  if (tab === 'chat') renderAdminChatList();
}

// ===================== DASHBOARD =====================
function updateDashboard() {
  const total = data.length;
  const done = data.filter(d => d.status === 'Selesai').length;
  const proc = data.filter(d => d.status === 'Diproses').length;
  const wait = data.filter(d => d.status === 'Menunggu').length;

  document.getElementById('kpiTotal').textContent = total;
  document.getElementById('kpiDone').textContent = done;
  document.getElementById('kpiDonePct').textContent = total > 0 ? Math.round(done/total*100) + '% selesai' : '0%';
  document.getElementById('kpiProcess').textContent = proc;
  document.getElementById('kpiWait').textContent = wait;

  renderBarChart();
  renderDonut();
  renderTable();
  renderAdminChatList();
  updateAdminChatBadge();
}

function renderBarChart() {
  const months = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date(); d.setMonth(d.getMonth() - i);
    months.push({ label: d.toLocaleString('id', {month:'short'}), key: d.toISOString().slice(0,7) });
  }
  const counts = months.map(m => data.filter(d => d.tanggal.startsWith(m.key)).length);
  const max = Math.max(...counts, 1);

  const bc = document.getElementById('barChart');
  bc.innerHTML = counts.map((c, i) => `
    <div class="bar-group">
      <div class="bar" style="height:${Math.max((c/max)*100,4)}px" title="${c} konsultasi"></div>
      <div class="bar-label">${months[i].label}</div>
    </div>
  `).join('');
}

function renderDonut() {
  const bidangList = ['Hukum Perdata','Hukum Pidana','Hukum Bisnis','Hukum Keluarga','Hukum Administrasi','HAKI','Lainnya'];
  const colors = ['#C9A84C','#52C97F','#5296C9','#C952A8','#E05252','#52C9C9','#888'];
  const counts = bidangList.map(b => data.filter(d => d.bidang === b).length);
  const total = counts.reduce((a,b)=>a+b,0) || 1;

  let offset = 0;
  const r = 45, cx = 60, cy = 60;
  let paths = '';
  counts.forEach((c, i) => {
    if (c === 0) return;
    const pct = c / total;
    const angle = pct * 2 * Math.PI;
    const x1 = cx + r * Math.sin(offset);
    const y1 = cy - r * Math.cos(offset);
    offset += angle;
    const x2 = cx + r * Math.sin(offset);
    const y2 = cy - r * Math.cos(offset);
    const large = pct > 0.5 ? 1 : 0;
    paths += `<path d="M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z" fill="${colors[i]}" opacity=".85"/>`;
  });

  document.getElementById('donutSvg').innerHTML = paths + `<circle cx="${cx}" cy="${cy}" r="22" fill="var(--card)"/>`;

  document.getElementById('donutLegend').innerHTML = bidangList.map((b, i) => {
    if (counts[i] === 0) return '';
    return `<div class="legend-item"><div class="legend-dot" style="background:${colors[i]}"></div><span>${b} (${counts[i]})</span></div>`;
  }).join('');
}

// ===================== TABEL DATA =====================
function renderTable() {
  const search = (document.getElementById('searchInput')?.value || '').toLowerCase();
  const fStatus = document.getElementById('filterStatus')?.value || '';
  const fBidang = document.getElementById('filterBidang')?.value || '';

  let filtered = data.filter(d => {
    const matchSearch = d.nama.toLowerCase().includes(search) || d.email.toLowerCase().includes(search);
    const matchStatus = !fStatus || d.status === fStatus;
    const matchBidang = !fBidang || d.bidang === fBidang;
    return matchSearch && matchStatus && matchBidang;
  });

  filtered.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    return sortAsc ? (va > vb ? 1 : -1) : (va < vb ? 1 : -1);
  });

  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = filtered.map(d => {
    const badgeClass = {Menunggu:'badge-pending', Diproses:'badge-process', Selesai:'badge-done', Dibatalkan:'badge-cancel'}[d.status] || 'badge-pending';
    return `<tr>
      <td>${d.id}</td>
      <td><strong>${d.nama}</strong><br><small style="color:var(--muted)">${d.email}</small></td>
      <td>${d.bidang}</td>
      <td style="font-size:.78rem">${d.urgensi}</td>
      <td><span class="badge ${badgeClass}">${d.status}</span></td>
      <td>${d.tanggal}</td>
      <td><div class="action-btns">
        <button class="btn-sm btn-view" onclick="viewDetail(${d.id})">Detail</button>
        <button class="btn-sm btn-done" onclick="setStatus(${d.id},'Selesai')">✓</button>
        <button class="btn-sm btn-del" onclick="hapus(${d.id})">✕</button>
      </div></td>
    </tr>`;
  }).join('');

  document.getElementById('tableInfo').textContent = `Menampilkan ${filtered.length} dari ${data.length} konsultasi`;
}

function sortTable(key) {
  if (sortKey === key) sortAsc = !sortAsc;
  else { sortKey = key; sortAsc = true; }
  renderTable();
}

function setStatus(id, status) {
  const idx = data.findIndex(d => d.id === id);
  if (idx !== -1) { data[idx].status = status; save(); renderTable(); updateDashboard(); showToast('Status diperbarui'); }
}

function hapus(id) {
  if (!confirm('Hapus data ini?')) return;
  data = data.filter(d => d.id !== id);
  save(); renderTable(); updateDashboard();
}

function hapusSelesai() {
  const jumlah = data.filter(d => d.status === 'Selesai').length;
  if (jumlah === 0) { showToast('Tidak ada konsultasi berstatus Selesai'); return; }
  if (!confirm(`Hapus ${jumlah} konsultasi yang sudah Selesai? Tindakan ini tidak dapat dibatalkan.`)) return;
  data = data.filter(d => d.status !== 'Selesai');
  save(); renderTable(); updateDashboard();
  showToast(`🗑️ ${jumlah} konsultasi selesai dihapus`);
}

function viewDetail(id) {
  const d = data.find(x => x.id === id);
  if (!d) return;
  document.getElementById('modalContent').innerHTML = `
    <div class="detail-row"><div class="detail-label">ID</div><div class="detail-value">#${d.id}</div></div>
    <div class="detail-row"><div class="detail-label">Nama</div><div class="detail-value">${d.nama}</div></div>
    <div class="detail-row"><div class="detail-label">NIK</div><div class="detail-value">${d.nik || '-'}</div></div>
    <div class="detail-row"><div class="detail-label">Email</div><div class="detail-value">${d.email}</div></div>
    <div class="detail-row"><div class="detail-label">Telepon</div><div class="detail-value">${d.telp}</div></div>
    <div class="detail-row"><div class="detail-label">Bidang</div><div class="detail-value">${d.bidang}</div></div>
    <div class="detail-row"><div class="detail-label">Urgensi</div><div class="detail-value">${d.urgensi}</div></div>
    <div class="detail-row"><div class="detail-label">Status</div><div class="detail-value">${d.status}</div></div>
    <div class="detail-row"><div class="detail-label">Alamat</div><div class="detail-value">${d.alamat || '-'}</div></div>
    <div class="detail-row"><div class="detail-label">Tanggal</div><div class="detail-value">${d.tanggal}</div></div>
    <div class="detail-row" style="flex-direction:column"><div class="detail-label">Deskripsi Masalah</div>
    <div class="detail-value" style="margin-top:6px;line-height:1.6;padding:10px;background:#1e1e1e;border-radius:8px">${d.deskripsi}</div></div>
    <div style="margin-top:16px;display:flex;gap:10px">
      <button class="btn-sm btn-done" style="padding:8px 18px" onclick="setStatus(${d.id},'Selesai');closeModal()">Tandai Selesai</button>
      <button class="btn-sm btn-view" style="padding:8px 18px" onclick="setStatus(${d.id},'Diproses');closeModal()">Set Diproses</button>
    </div>`;
  document.getElementById('modalOverlay').classList.add('open');
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('open'); }

document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ===================== EXPORT CSV =====================
function exportCSV() {
  const headers = ['ID','Nama','NIK','Email','Telepon','Bidang','Urgensi','Status','Alamat','Tanggal','Deskripsi'];
  const rows = data.map(d => [d.id,d.nama,d.nik,d.email,d.telp,d.bidang,d.urgensi,d.status,d.alamat,d.tanggal,d.deskripsi?.replace(/,/g,' ')]);
  const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'laporan-konsultasi-' + new Date().toISOString().split('T')[0] + '.csv';
  a.click();
  showToast('⬇ CSV berhasil diexport!');
}

// ===================== PEMBAYARAN =====================
function formatRupiahAdmin(n) {
  return 'Rp ' + Number(n || 0).toLocaleString('id-ID');
}

function payBadgeClass(status) {
  return {
    'Menunggu Verifikasi': 'badge-pending',
    'Lunas': 'badge-done',
    'Pengajuan Gratis': 'badge-gratis',
    'Disetujui': 'badge-done',
    'Ditolak': 'badge-cancel'
  }[status] || 'badge-pending';
}

function updatePayBadge(viewed) {
  const badge = document.getElementById('payBadgeTab');
  const pending = payData.filter(p => p.status === 'Menunggu Verifikasi' || p.status === 'Pengajuan Gratis').length;
  if (pending > 0 && !viewed) {
    badge.style.display = 'inline-block';
    badge.textContent = pending;
  } else {
    badge.style.display = 'none';
  }
}

function renderPaymentTable() {
  const search = (document.getElementById('paySearchInput')?.value || '').toLowerCase();
  const fStatus = document.getElementById('payFilterStatus')?.value || '';

  let filtered = payData.filter(p => {
    const matchSearch = (p.nama||'').toLowerCase().includes(search) || (p.kode||'').toLowerCase().includes(search);
    const matchStatus = !fStatus || p.status === fStatus;
    return matchSearch && matchStatus;
  });

  filtered.sort((a, b) => {
    let va = a[paySortKey], vb = b[paySortKey];
    if (typeof va === 'string') va = va.toLowerCase();
    if (typeof vb === 'string') vb = vb.toLowerCase();
    return paySortAsc ? (va > vb ? 1 : -1) : (va < vb ? 1 : -1);
  });

  const tbody = document.getElementById('payTableBody');
  if (filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;color:var(--muted);padding:24px">Belum ada data pembayaran.</td></tr>`;
  } else {
    tbody.innerHTML = filtered.map(p => {
      const badgeClass = payBadgeClass(p.status);
      const jumlah = p.harga > 0 ? formatRupiahAdmin(p.harga) : 'GRATIS';
      const adaBukti = !!(p.bukti && p.bukti.dataUrl);
      const buktiCol = p.harga > 0
        ? (adaBukti ? '<span style="color:var(--success);font-weight:700">✓ Ada</span>' : '<span style="color:var(--danger);font-weight:700">✕ Belum</span>')
        : '<span style="color:var(--muted)">-</span>';
      let aksiBtns = '';
      if (p.status === 'Menunggu Verifikasi') {
        aksiBtns = adaBukti
          ? `<button class="btn-sm btn-done" onclick="setPayStatus(${p.id},'Lunas')">✓ Lunas</button>`
          : `<button class="btn-sm btn-done" disabled title="Klien belum upload bukti pembayaran" style="opacity:.4;cursor:not-allowed">✓ Lunas</button>`;
      } else if (p.status === 'Pengajuan Gratis') {
        aksiBtns = `<button class="btn-sm btn-done" onclick="setPayStatus(${p.id},'Disetujui')">✓ Setuju</button>
                     <button class="btn-sm btn-del" onclick="setPayStatus(${p.id},'Ditolak')">✕ Tolak</button>`;
      }
      return `<tr>
        <td>${p.id}</td>
        <td><strong>${p.nama}</strong></td>
        <td>${p.paket}</td>
        <td style="font-size:.78rem">${p.metode}</td>
        <td>${jumlah}</td>
        <td style="font-family:monospace;font-size:.78rem">${p.kode}</td>
        <td style="font-size:.78rem">${buktiCol}</td>
        <td><span class="badge ${badgeClass}">${p.status}</span></td>
        <td style="font-size:.78rem">${p.tanggal}</td>
        <td><div class="action-btns">
          <button class="btn-sm btn-view" onclick="viewPayDetail(${p.id})">Detail</button>
          ${aksiBtns}
          <button class="btn-sm btn-del" onclick="hapusPay(${p.id})">✕</button>
        </div></td>
      </tr>`;
    }).join('');
  }

  document.getElementById('payTableInfo').textContent = `Menampilkan ${filtered.length} dari ${payData.length} transaksi`;
}

function hapusPay(id) {
  if (!confirm('Hapus riwayat pembayaran ini?')) return;
  payData = payData.filter(p => p.id !== id);
  savePayData();
  renderPaymentTable();
  updatePayBadge(true);
  showToast('🗑️ Riwayat pembayaran dihapus');
}

function hapusSemuaPembayaran() {
  if (payData.length === 0) { showToast('Belum ada riwayat pembayaran'); return; }
  if (!confirm(`Hapus SEMUA ${payData.length} riwayat pembayaran & pengajuan gratis? Tindakan ini tidak dapat dibatalkan.`)) return;
  payData = [];
  savePayData();
  renderPaymentTable();
  updatePayBadge(true);
  showToast('🗑️ Semua riwayat pembayaran dihapus');
}

function setPayStatus(id, status) {
  const idx = payData.findIndex(p => p.id === id);
  if (idx !== -1) {
    if (status === 'Lunas' && payData[idx].harga > 0 && !(payData[idx].bukti && payData[idx].bukti.dataUrl)) {
      showToast('⚠️ Klien belum mengunggah bukti pembayaran!');
      return;
    }
    payData[idx].status = status;
    if (status === 'Ditolak') payData[idx].notifRead = false;
    savePayData();
    renderPaymentTable();
    updatePayBadge(true);
    showToast('Status pembayaran diperbarui: ' + status);
  }
}

function viewPayDetail(id) {
  const p = payData.find(x => x.id === id);
  if (!p) return;
  let bukti = '';
  if (p.bukti && p.bukti.dataUrl) {
    if (p.bukti.type && p.bukti.type.startsWith('image/')) {
      bukti = `
    <div class="detail-row" style="flex-direction:column"><div class="detail-label">Bukti Pembayaran</div>
    <div class="detail-value" style="margin-top:8px">
      <a href="${p.bukti.dataUrl}" target="_blank" title="Klik untuk perbesar">
        <img src="${p.bukti.dataUrl}" alt="Bukti pembayaran" style="max-width:100%;max-height:320px;border-radius:8px;border:1px solid var(--border);display:block">
      </a>
    </div></div>`;
    } else {
      bukti = `
    <div class="detail-row"><div class="detail-label">Bukti Pembayaran</div><div class="detail-value">
      <a href="${p.bukti.dataUrl}" download="${escapeHtml(p.bukti.name || 'bukti')}" style="color:var(--gold);font-weight:600">📄 ${escapeHtml(p.bukti.name || 'Lihat / Unduh File')}</a>
    </div></div>`;
    }
  } else if (p.status === 'Menunggu Verifikasi') {
    bukti = `
    <div class="detail-row"><div class="detail-label">Bukti Pembayaran</div><div class="detail-value" style="color:var(--danger)">⚠️ Belum ada bukti diunggah</div></div>`;
  }
  let extra = '';
  if (p.kategori) {
    extra = `
    <div class="detail-row"><div class="detail-label">Kategori</div><div class="detail-value">${p.kategori}</div></div>
    <div class="detail-row" style="flex-direction:column"><div class="detail-label">Alasan / Kondisi</div>
    <div class="detail-value" style="margin-top:6px;line-height:1.6;padding:10px;background:#1e1e1e;border-radius:8px">${p.alasan || '-'}</div></div>
    <div class="detail-row"><div class="detail-label">Dokumen Pendukung</div><div class="detail-value">${p.dokumen || '-'}</div></div>`;
  }
  let aksi = '';
  if (p.status === 'Menunggu Verifikasi') {
    const adaBuktiModal = !!(p.bukti && p.bukti.dataUrl);
    aksi = adaBuktiModal
      ? `<button class="btn-sm btn-done" style="padding:8px 18px" onclick="setPayStatus(${p.id},'Lunas');closeModal()">Tandai Lunas</button>`
      : `<button class="btn-sm btn-done" style="padding:8px 18px;opacity:.4;cursor:not-allowed" disabled title="Klien belum upload bukti pembayaran">Tandai Lunas</button>`;
  } else if (p.status === 'Pengajuan Gratis') {
    aksi = `<button class="btn-sm btn-done" style="padding:8px 18px" onclick="setPayStatus(${p.id},'Disetujui');closeModal()">Setujui Pengajuan</button>
            <button class="btn-sm btn-del" style="padding:8px 18px" onclick="setPayStatus(${p.id},'Ditolak');closeModal()">Tolak Pengajuan</button>`;
  }
  document.getElementById('modalContent').innerHTML = `
    <div class="detail-row"><div class="detail-label">ID</div><div class="detail-value">#${p.id}</div></div>
    <div class="detail-row"><div class="detail-label">Klien</div><div class="detail-value">${p.nama}</div></div>
    <div class="detail-row"><div class="detail-label">Paket</div><div class="detail-value">${p.paket}</div></div>
    <div class="detail-row"><div class="detail-label">Metode</div><div class="detail-value">${p.metode}</div></div>
    <div class="detail-row"><div class="detail-label">Jumlah</div><div class="detail-value">${p.harga > 0 ? formatRupiahAdmin(p.harga) : 'GRATIS'}</div></div>
    <div class="detail-row"><div class="detail-label">Kode</div><div class="detail-value">${p.kode}</div></div>
    <div class="detail-row"><div class="detail-label">Status</div><div class="detail-value">${p.status}</div></div>
    <div class="detail-row"><div class="detail-label">Tanggal</div><div class="detail-value">${p.tanggal}</div></div>
    ${bukti}
    ${extra}
    <div style="margin-top:16px;display:flex;gap:10px">${aksi}</div>`;
  document.getElementById('modalOverlay').classList.add('open');
}

function exportPaymentCSV() {
  const headers = ['ID','Klien','Paket','Metode','Jumlah','Kode','Status','Tanggal'];
  const rows = payData.map(p => [p.id, p.nama, p.paket, p.metode, p.harga, p.kode, p.status, p.tanggal?.replace(/,/g,' ')]);
  const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'laporan-pembayaran-' + new Date().toISOString().split('T')[0] + '.csv';
  a.click();
  showToast('⬇ CSV berhasil diexport!');
}

// ===================== TOAST =====================
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 2800);
}

// ===================== CHAT (SISI ADMIN) =====================
let chatStore = {};
let activeChatId = null;

function loadChat() {
  try { return JSON.parse(localStorage.getItem(LS_CHAT) || '{}'); }
  catch(e) { return {}; }
}
function saveChat() {
  localStorage.setItem(LS_CHAT, JSON.stringify(chatStore));
}

function nowTime() {
  return new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
}
function nowFull() {
  return new Date().toLocaleString('id-ID', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
}
function escapeHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderAdminChatList() {
  chatStore = loadChat();
  const list = document.getElementById('adminChatList');
  const countEl = document.getElementById('adminChatCount');
  let ids = Object.keys(chatStore);

  if (countEl) countEl.textContent = ids.length > 0 ? `(${ids.length})` : '';

  if (ids.length === 0) {
    list.innerHTML = '<div style="padding:32px 16px;text-align:center;color:var(--muted);font-size:.84rem">Belum ada percakapan masuk.</div>';
    return;
  }

  // Urutkan: yang ada pesan belum dibaca admin di atas, lalu berdasarkan pesan terakhir terbaru
  ids.sort((a, b) => {
    const ca = chatStore[a], cb = chatStore[b];
    const ua = ca.unreadAdmin || 0, ub = cb.unreadAdmin || 0;
    if (ua !== ub) return ub - ua;
    const ta = ca.messages?.[ca.messages.length - 1]?.timeFull || '';
    const tb = cb.messages?.[cb.messages.length - 1]?.timeFull || '';
    return tb.localeCompare(ta);
  });

  list.innerHTML = '';
  ids.forEach(id => {
    const c = chatStore[id];
    const lastMsg = c.messages[c.messages.length - 1];
    const initials = (c.name || 'K').split(' ').map(w => w[0]).join('').substr(0,2).toUpperCase();
    const div = document.createElement('div');
    div.className = 'chat-list-item' + (activeChatId === id ? ' active' : '');
    div.onclick = () => openAdminChat(id);
    div.innerHTML = `
      <div class="chat-avatar">${initials}</div>
      <div class="chat-item-info">
        <div class="chat-item-name">${escapeHtml(c.name)}</div>
        <div class="chat-item-preview">${lastMsg ? escapeHtml(lastMsg.text) : ''}</div>
      </div>
      <div class="chat-item-time">${lastMsg ? lastMsg.time : ''}</div>
      ${c.unreadAdmin > 0 ? `<div class="chat-unread">${c.unreadAdmin}</div>` : ''}
      <button class="btn-sm btn-del" style="position:absolute;bottom:10px;right:10px;padding:3px 8px;font-size:.68rem" onclick="event.stopPropagation();hapusChat('${id}')">✕</button>`;
    div.style.position = 'relative';
    list.appendChild(div);
  });
}

function hapusChat(id) {
  if (!confirm('Hapus percakapan ini? Semua pesan dengan klien ini akan hilang.')) return;
  chatStore = loadChat();
  delete chatStore[id];
  saveChat();
  if (activeChatId === id) {
    activeChatId = null;
    document.getElementById('chatActiveArea').style.display = 'none';
    document.getElementById('chatEmptyState').style.display = 'flex';
  }
  renderAdminChatList();
  updateAdminChatBadge();
  showToast('🗑️ Percakapan dihapus');
}

function hapusSemuaChat() {
  chatStore = loadChat();
  const jumlah = Object.keys(chatStore).length;
  if (jumlah === 0) { showToast('Belum ada percakapan'); return; }
  if (!confirm(`Hapus SEMUA ${jumlah} percakapan klien? Tindakan ini tidak dapat dibatalkan.`)) return;
  chatStore = {};
  saveChat();
  activeChatId = null;
  document.getElementById('chatActiveArea').style.display = 'none';
  document.getElementById('chatEmptyState').style.display = 'flex';
  renderAdminChatList();
  updateAdminChatBadge();
  showToast('🗑️ Semua percakapan dihapus');
}

function openAdminChat(id) {
  activeChatId = id;
  chatStore = loadChat();
  const c = chatStore[id];
  if (!c) return;
  c.unreadAdmin = 0;
  saveChat();
  updateAdminChatBadge();
  renderAdminChatList();

  document.getElementById('chatEmptyState').style.display = 'none';
  const activeArea = document.getElementById('chatActiveArea');
  activeArea.style.display = 'flex';

  const initials = (c.name || 'K').split(' ').map(w => w[0]).join('').substr(0,2).toUpperCase();
  document.getElementById('chatTopbar').innerHTML = `
    <div class="chat-topbar-avatar">${initials}</div>
    <div class="chat-topbar-info">
      <div class="chat-topbar-name">${escapeHtml(c.name)}</div>
      <div class="chat-topbar-status">● Online</div>
    </div>
    <div class="chat-topbar-badge">${escapeHtml(c.bidang)}</div>`;

  const box = document.getElementById('adminMessages');
  box.innerHTML = '';
  const divider = document.createElement('div');
  divider.className = 'chat-date-divider';
  divider.innerHTML = '<span>Hari ini</span>';
  box.appendChild(divider);

  c.messages.forEach(msg => appendAdminMsg(msg, c));
  box.scrollTop = box.scrollHeight;
  document.getElementById('adminInput').focus();
}

function appendAdminMsg(msg, c) {
  const box = document.getElementById('adminMessages');
  if (!box) return;
  const isAdmin = msg.from === 'admin';
  const div = document.createElement('div');
  div.className = 'chat-msg ' + (isAdmin ? 'msg-admin' : 'msg-client');
  div.innerHTML = `
    <div class="msg-avatar ${isAdmin ? 'av-admin' : 'av-client'}">${isAdmin ? '⚖' : '👤'}</div>
    <div class="msg-wrap">
      <div class="msg-bubble ${isAdmin ? 'bubble-admin' : 'bubble-client'}">${escapeHtml(msg.text)}</div>
      <div class="msg-time">${isAdmin ? 'Admin' : escapeHtml((c || chatStore[activeChatId])?.name || 'Klien')} · ${msg.time}</div>
    </div>`;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
}

function adminSend() {
  chatStore = loadChat();
  if (!activeChatId || !chatStore[activeChatId]) {
    showToast('⚠️ Pilih percakapan klien dulu!');
    return;
  }
  const inp = document.getElementById('adminInput');
  const text = inp.value.trim();
  if (!text) return;

  const msg = { from: 'admin', text, time: nowTime(), timeFull: nowFull() };
  chatStore[activeChatId].messages.push(msg);
  chatStore[activeChatId].unreadClient = (chatStore[activeChatId].unreadClient || 0) + 1;
  saveChat();

  appendAdminMsg(msg, chatStore[activeChatId]);
  inp.value = '';
  inp.style.height = 'auto';
  renderAdminChatList();

  showToast('✅ Balasan terkirim ke klien!');
}

function updateAdminChatBadge() {
  chatStore = loadChat();
  const total = Object.values(chatStore).reduce((s, c) => s + (c.unreadAdmin || 0), 0);
  const badge = document.getElementById('chatBadgeTab');
  if (total > 0) {
    badge.style.display = 'inline';
    badge.textContent = total;
  } else {
    badge.style.display = 'none';
  }
}

// ===================== SINKRONISASI ANTAR HALAMAN =====================
// Saat klien.html mengubah localStorage (konsultasi baru / chat baru),
// dashboard ini akan otomatis menyegarkan tampilan.
window.addEventListener('storage', (e) => {
  if (!sessionStorage.getItem(SESSION_KEY)) return;
  if (e.key === LS_DATA) {
    data = loadData();
    updateDashboard();
  }
  if (e.key === LS_PAY) {
    payData = loadPayData();
    renderPaymentTable();
    updatePayBadge();
  }
  if (e.key === LS_CHAT) {
    renderAdminChatList();
    updateAdminChatBadge();
    if (activeChatId) {
      const c = loadChat()[activeChatId];
      if (c) {
        const box = document.getElementById('adminMessages');
        const rendered = box.querySelectorAll('.chat-msg').length;
        if (c.messages.length > rendered) {
          c.messages.slice(rendered).forEach(msg => appendAdminMsg(msg, c));
        }
      }
    }
  }
});

// Polling cadangan (untuk browser yang tidak memicu event 'storage' tepat waktu)
setInterval(() => {
  if (!sessionStorage.getItem(SESSION_KEY)) return;
  const fresh = loadData();
  if (JSON.stringify(fresh) !== JSON.stringify(data)) {
    data = fresh;
    updateDashboard();
  }
  const freshPay = loadPayData();
  if (JSON.stringify(freshPay) !== JSON.stringify(payData)) {
    payData = freshPay;
    renderPaymentTable();
    updatePayBadge(document.getElementById('tab-pembayaran').style.display === 'block');
  }
  renderAdminChatList();
  updateAdminChatBadge();
}, 3000);

// ===================== INIT =====================
// Jika sesi login masih aktif (tab/halaman direfresh), langsung tampilkan dashboard
if (sessionStorage.getItem(SESSION_KEY) === '1') {
  enterAdmin();
}
