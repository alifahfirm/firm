<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AlifahLawFirm – Admin Panel</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8CC82;
    --dark: #0D0D0D;
    --darker: #070707;
    --card: #161616;
    --border: #2a2a2a;
    --text: #E8E4DC;
    --muted: #888;
    --accent: #C9A84C;
    --danger: #E05252;
    --success: #52C97F;
    --info: #5296C9;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--darker);
    color: var(--text);
    min-height: 100vh;
  }

  /* NAV */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 48px;
    border-bottom: 1px solid var(--border);
    background: rgba(13,13,13,0.95);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: var(--gold);
    letter-spacing: 1px;
  }
  .logo span { color: var(--text); }

  nav ul { list-style:none; display:flex; gap:28px; }
  nav ul li a {
    text-decoration:none;
    color: var(--muted);
    font-size: .9rem;
    font-weight: 500;
    transition: color .2s;
  }
  nav ul li a:hover, nav ul li a.active { color: var(--gold); }

  .btn-nav {
    background: var(--gold);
    color: var(--dark);
    border: none;
    padding: 9px 22px;
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: .85rem;
    cursor: pointer;
    transition: background .2s;
  }
  .btn-nav:hover { background: var(--gold-light); }

  /* PAGES */
  .page { display:none; }
  .page.active { display:block; }

  /* HERO */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    padding: 90px 24px 60px;
    background: radial-gradient(ellipse at 50% 0%, rgba(201,168,76,0.08) 0%, transparent 65%);
  }

  .hero-badge {
    display: inline-block;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold);
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 20px;
    margin-bottom: 24px;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.15;
    max-width: 700px;
    margin-bottom: 20px;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--gold);
  }

  .hero p {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 36px;
  }

  .hero-btns { display:flex; gap:14px; flex-wrap:wrap; justify-content:center; }

  .btn-primary {
    background: var(--gold);
    color: var(--dark);
    border: none;
    padding: 13px 30px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: .95rem;
    cursor: pointer;
    transition: all .2s;
    letter-spacing: .3px;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    padding: 13px 30px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: .95rem;
    cursor: pointer;
    transition: all .2s;
  }
  .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

  /* STATS */
  .stats {
    display: flex;
    justify-content: center;
    gap: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin: 0;
    background: var(--card);
  }
  .stat {
    flex: 1;
    max-width: 200px;
    text-align: center;
    padding: 28px 20px;
    border-right: 1px solid var(--border);
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--gold);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label { font-size: .78rem; color: var(--muted); font-weight: 500; }

  /* SERVICES */
  .section {
    padding: 72px 48px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    margin-bottom: 8px;
  }
  .section-sub { color: var(--muted); font-size: .95rem; margin-bottom: 40px; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
  }

  .service-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    transition: border-color .2s, transform .2s;
    cursor: pointer;
  }
  .service-card:hover { border-color: var(--gold); transform: translateY(-4px); }

  .service-icon {
    width: 44px;
    height: 44px;
    background: rgba(201,168,76,0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    margin-bottom: 16px;
  }

  .service-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    margin-bottom: 8px;
    color: var(--text);
  }
  .service-card p { font-size: .85rem; color: var(--muted); line-height: 1.6; }

  /* FORM */
  .form-section {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    max-width: 700px;
    margin: 0 auto;
  }

  .form-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 6px;
  }
  .form-sub { color: var(--muted); font-size: .9rem; margin-bottom: 32px; }

  .form-row { display: flex; gap: 16px; }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-bottom: 18px;
    flex: 1;
  }

  label { font-size: .82rem; font-weight: 600; color: #aaa; letter-spacing: .4px; }

  input, select, textarea {
    background: #1e1e1e;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 11px 14px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: .9rem;
    outline: none;
    transition: border-color .2s;
    width: 100%;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--gold); }
  textarea { resize: vertical; min-height: 120px; }
  select option { background: #1e1e1e; }

  .submit-btn {
    width: 100%;
    background: var(--gold);
    color: var(--dark);
    border: none;
    padding: 14px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all .2s;
    margin-top: 8px;
  }
  .submit-btn:hover { background: var(--gold-light); }

  /* DASHBOARD */
  .dash-header {
    padding: 40px 48px 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .dash-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 6px;
  }
  .dash-header p { color: var(--muted); font-size: .9rem; margin-bottom: 24px; }

  .dash-tabs { display:flex; gap:0; flex-wrap:wrap; }
  .dash-tab {
    padding: 10px 22px;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    color: var(--muted);
    transition: all .2s;
    background: none;
    border-top: none; border-left: none; border-right: none;
    font-family: 'DM Sans', sans-serif;
  }
  .dash-tab.active { color: var(--gold); border-bottom-color: var(--gold); }

  .dash-body { padding: 0 48px 48px; }

  /* KPI CARDS */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .kpi-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 22px 20px;
  }
  .kpi-label { font-size: .75rem; color: var(--muted); font-weight: 600; letter-spacing: .4px; margin-bottom: 10px; text-transform: uppercase; }
  .kpi-value {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--text);
    line-height: 1;
    margin-bottom: 6px;
  }
  .kpi-change { font-size: .78rem; font-weight: 600; }
  .kpi-change.up { color: var(--success); }
  .kpi-change.down { color: var(--danger); }
  .kpi-change.neu { color: var(--muted); }

  /* TABLE */
  .table-wrap {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .table-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
  }
  .table-head h3 { font-size: .95rem; font-weight: 600; }
  .table-head span { font-size: .8rem; color: var(--muted); }

  .filter-row {
    display: flex;
    gap: 10px;
    padding: 14px 22px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .filter-row input, .filter-row select {
    max-width: 200px;
    padding: 7px 12px;
    font-size: .82rem;
  }

  table { width:100%; border-collapse:collapse; }
  thead tr { background: #1a1a1a; }
  th {
    padding: 12px 16px;
    font-size: .75rem;
    font-weight: 700;
    color: var(--muted);
    text-align: left;
    letter-spacing: .5px;
    text-transform: uppercase;
    cursor: pointer;
    user-select: none;
  }
  th:hover { color: var(--gold); }
  td {
    padding: 13px 16px;
    font-size: .84rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(201,168,76,0.03); }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: .72rem;
    font-weight: 700;
  }
  .badge-pending { background: rgba(201,168,76,0.15); color: var(--gold); }
  .badge-done { background: rgba(82,201,127,0.15); color: var(--success); }
  .badge-process { background: rgba(82,150,201,0.15); color: var(--info); }
  .badge-cancel { background: rgba(224,82,82,0.15); color: var(--danger); }
  .badge-gratis { background: rgba(76,175,80,0.15); color: #4CAF50; }

  /* ACTION BUTTONS */
  .action-btns { display:flex; gap:6px; }
  .btn-sm {
    padding: 5px 12px;
    border-radius: 5px;
    font-size: .75rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    font-family: 'DM Sans', sans-serif;
    transition: all .15s;
  }
  .btn-view { background: rgba(82,150,201,0.15); color: var(--info); }
  .btn-view:hover { background: rgba(82,150,201,0.3); }
  .btn-done { background: rgba(82,201,127,0.15); color: var(--success); }
  .btn-done:hover { background: rgba(82,201,127,0.3); }
  .btn-del { background: rgba(224,82,82,0.15); color: var(--danger); }
  .btn-del:hover { background: rgba(224,82,82,0.3); }

  /* CHARTS AREA */
  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .chart-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 22px;
  }

  .chart-card h3 { font-size: .9rem; font-weight: 600; margin-bottom: 18px; color: #ccc; }

  .bar-chart { display:flex; align-items:flex-end; gap:10px; height:120px; }
  .bar-group { display:flex; flex-direction:column; align-items:center; gap:6px; flex:1; }
  .bar {
    width: 100%;
    background: var(--gold);
    border-radius: 4px 4px 0 0;
    min-height: 4px;
    transition: opacity .2s;
  }
  .bar:hover { opacity: .75; }
  .bar-label { font-size: .68rem; color: var(--muted); }

  .donut-wrap { display:flex; align-items:center; gap:24px; }
  .donut-svg { flex-shrink:0; }
  .legend { display:flex; flex-direction:column; gap:10px; }
  .legend-item { display:flex; align-items:center; gap:8px; font-size: .8rem; }
  .legend-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }

  /* EXPORT BTN */
  .export-btn {
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold);
    padding: 8px 20px;
    border-radius: 7px;
    font-family: 'DM Sans', sans-serif;
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
  }
  .export-btn:hover { background: rgba(201,168,76,0.2); }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 999;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    max-width: 520px;
    width: 92%;
    position: relative;
  }
  .modal h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    margin-bottom: 20px;
    color: var(--gold);
  }
  .modal-close {
    position: absolute;
    top: 16px; right: 20px;
    background: none; border: none;
    color: var(--muted); font-size: 1.4rem;
    cursor: pointer;
  }
  .detail-row { display:flex; gap:12px; margin-bottom: 12px; }
  .detail-label { font-size: .78rem; font-weight: 600; color: var(--muted); min-width: 110px; }
  .detail-value { font-size: .88rem; color: var(--text); }

  .toast {
    position: fixed;
    bottom: 28px; right: 28px;
    background: var(--success);
    color: #fff;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: .88rem;
    z-index: 9999;
    display: none;
    animation: slideUp .3s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity:0; }
    to { transform: translateY(0); opacity:1; }
  }

  /* PEMBAYARAN */
  .pay-layout { max-width:900px; margin:0 auto; padding:48px 24px; }
  .pay-title { font-family:'Playfair Display',serif; font-size:2rem; margin-bottom:6px; }
  .pay-sub { color:var(--muted); font-size:.92rem; margin-bottom:36px; }
  .paket-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:36px; }
  .paket-card { background:var(--card); border:1.5px solid var(--border); border-radius:14px; padding:24px 20px; cursor:pointer; transition:all .2s; position:relative; }
  .paket-card:hover { border-color:var(--gold); transform:translateY(-3px); }
  .paket-card.selected { border-color:var(--gold); background:rgba(201,168,76,0.06); }
  .paket-badge { position:absolute; top:-10px; left:50%; transform:translateX(-50%); background:var(--gold); color:var(--dark); font-size:.68rem; font-weight:700; padding:3px 12px; border-radius:20px; letter-spacing:.5px; white-space:nowrap; }
  .paket-icon { font-size:1.8rem; margin-bottom:10px; }
  .paket-name { font-family:'Playfair Display',serif; font-size:1.05rem; margin-bottom:4px; }
  .paket-desc { font-size:.78rem; color:var(--muted); margin-bottom:14px; line-height:1.5; }
  .paket-price { font-family:'Playfair Display',serif; font-size:1.5rem; color:var(--gold); font-weight:700; }
  .paket-price span { font-size:.78rem; color:var(--muted); font-weight:400; font-family:'DM Sans',sans-serif; }
  .metode-section { margin-bottom:32px; }
  .metode-label { font-size:.82rem; font-weight:700; color:#aaa; letter-spacing:.5px; margin-bottom:14px; }
  .metode-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; }
  .metode-card { background:var(--card); border:1.5px solid var(--border); border-radius:12px; padding:16px 14px; cursor:pointer; transition:all .2s; text-align:center; }
  .metode-card:hover { border-color:var(--gold); }
  .metode-card.selected { border-color:var(--gold); background:rgba(201,168,76,0.06); }
  .metode-logo { font-size:1.6rem; margin-bottom:6px; }
  .metode-logo svg { display:block; margin:0 auto; border-radius:8px; }
  .metode-group-label {
    font-size:.75rem;
    font-weight:700;
    color:var(--muted);
    letter-spacing:.8px;
    text-transform:uppercase;
    margin-bottom:10px;
    padding-bottom:6px;
    border-bottom:1px solid var(--border);
  }
  .metode-name { font-size:.8rem; font-weight:600; color:var(--text); }
  .metode-type { font-size:.7rem; color:var(--muted); margin-top:2px; }
  .pay-detail-box { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:28px; margin-bottom:24px; display:none; }
  .pay-detail-box.show { display:block; }
  .pay-detail-title { font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--gold); margin-bottom:20px; }
  .pay-info-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--border); font-size:.88rem; }
  .pay-info-row:last-of-type { border-bottom:none; }
  .pay-info-label { color:var(--muted); }
  .pay-info-value { font-weight:600; color:var(--text); }
  .pay-info-value.gold { color:var(--gold); }
  .qris-box { text-align:center; padding:20px 0 8px; }
  .qris-frame { display:inline-block; background:#fff; padding:16px; border-radius:12px; margin-bottom:10px; }
  .qris-note { font-size:.8rem; color:var(--muted); }
  .rekening-box { margin-top:12px; }
  .rek-item { background:#1e1e1e; border:1px solid var(--border); border-radius:10px; padding:14px 18px; margin-bottom:10px; display:flex; align-items:center; justify-content:space-between; gap:12px; }
  .rek-bank { font-weight:700; font-size:.92rem; color:var(--gold); }
  .rek-num { font-family:monospace; font-size:1rem; color:var(--text); letter-spacing:2px; margin:2px 0; }
  .rek-name { font-size:.78rem; color:var(--muted); }
  .copy-btn { background:rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.3); color:var(--gold); padding:6px 14px; border-radius:7px; font-size:.75rem; font-weight:600; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all .2s; white-space:nowrap; }
  .copy-btn:hover { background:rgba(201,168,76,0.25); }
  .pay-summary { background:rgba(201,168,76,0.06); border:1px solid rgba(201,168,76,0.2); border-radius:12px; padding:18px 22px; margin-bottom:20px; display:flex; justify-content:space-between; align-items:center; }
  .pay-summary-label { font-size:.85rem; color:var(--muted); }
  .pay-summary-total { font-family:'Playfair Display',serif; font-size:1.6rem; color:var(--gold); font-weight:700; }
  .pay-confirm-btn { width:100%; background:var(--gold); color:var(--dark); border:none; padding:15px; border-radius:10px; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; cursor:pointer; transition:all .2s; margin-top:4px; }
  .pay-confirm-btn:hover { background:var(--gold-light); transform:translateY(-2px); }
  .pay-confirm-btn:disabled { background:#444; color:#888; cursor:not-allowed; transform:none; }
  .pay-success { text-align:center; padding:48px 24px; display:none; }
  .pay-success.show { display:block; }
  .pay-success-icon { font-size:4rem; margin-bottom:16px; }
  .pay-success h2 { font-family:'Playfair Display',serif; font-size:1.8rem; color:var(--success); margin-bottom:8px; }
  .pay-success p { color:var(--muted); font-size:.95rem; margin-bottom:24px; }

  /* CHAT */
  .chat-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    height: calc(100vh - 180px);
    min-height: 500px;
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--card);
  }

  .chat-sidebar {
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    background: #111;
  }

  .chat-sidebar-header {
    padding: 18px 16px 14px;
    border-bottom: 1px solid var(--border);
    font-size: .82rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: .5px;
    text-transform: uppercase;
  }

  .chat-list {
    flex: 1;
    overflow-y: auto;
  }

  .chat-list-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    cursor: pointer;
